# Copy to .env. None of this is required for the offline --mock path.

# Gateway API keys (comma-separated). Default if unset: "demo-key".
INFSVC_API_KEYS=demo-key

# Per-key rate limit (requests per minute).
INFSVC_RATE_RPM=120

# Backends the gateway routes to (mock profiles or real engines).
INFSVC_PRIMARY_BACKEND=mock
INFSVC_PRIMARY_PROFILE=vllm
INFSVC_FALLBACK_BACKEND=mock
INFSVC_FALLBACK_PROFILE=awq

# Real engine endpoints (used only by vllm/tgi backends).
INFSVC_VLLM_URL=http://localhost:8000/v1
INFSVC_TGI_URL=http://localhost:8080
