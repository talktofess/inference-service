{
  "title": "Inference Service",
  "uid": "infsvc",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "5s",
  "time": { "from": "now-15m", "to": "now" },
  "panels": [
    {
      "id": 1, "title": "Throughput (completion tokens/sec)", "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "targets": [
        { "expr": "sum(rate(infsvc_tokens_total{kind=\"completion\"}[1m]))", "legendFormat": "tok/s" }
      ]
    },
    {
      "id": 2, "title": "Request latency p50/p95/p99 (ms)", "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "targets": [
        { "expr": "histogram_quantile(0.50, sum(rate(infsvc_request_latency_ms_bucket[1m])) by (le))", "legendFormat": "p50" },
        { "expr": "histogram_quantile(0.95, sum(rate(infsvc_request_latency_ms_bucket[1m])) by (le))", "legendFormat": "p95" },
        { "expr": "histogram_quantile(0.99, sum(rate(infsvc_request_latency_ms_bucket[1m])) by (le))", "legendFormat": "p99" }
      ]
    },
    {
      "id": 3, "title": "In-flight requests (queue depth)", "type": "timeseries",
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 8 },
      "targets": [ { "expr": "infsvc_inflight_requests", "legendFormat": "inflight" } ]
    },
    {
      "id": 4, "title": "Error rate (req/s)", "type": "timeseries",
      "gridPos": { "h": 8, "w": 8, "x": 8, "y": 8 },
      "targets": [ { "expr": "sum(rate(infsvc_requests_total{status=\"error\"}[1m]))", "legendFormat": "errors/s" } ]
    },
    {
      "id": 5, "title": "Cumulative cost (USD)", "type": "timeseries",
      "gridPos": { "h": 8, "w": 8, "x": 16, "y": 8 },
      "targets": [ { "expr": "sum(infsvc_cost_usd_total)", "legendFormat": "USD" } ]
    }
  ]
}
